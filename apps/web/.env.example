# URL base do relay WebSocket para sincronização Yjs
# Desenvolvimento local (browser):
VITE_RELAY_URL=ws://localhost:8765/sync

# Desenvolvimento local (Android físico — substituir pelo IP da máquina):
# VITE_RELAY_URL=ws://192.168.1.100:8765/sync

# Produção:
# VITE_RELAY_URL=wss://relay.kryptua.app/sync
